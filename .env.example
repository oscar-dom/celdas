## =====================================================================
## Environment variables template for Celdas
## =====================================================================
## Copy this file to `.env.local` (gitignored) and fill in real values.
## Never commit `.env.local`.
##
## Variable naming:
##   NEXT_PUBLIC_*  → exposed to the browser (safe to be public)
##   anything else  → server-only (never reaches the client bundle)
## =====================================================================

# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, bypasses RLS

# ---------------------------------------------------------------------
# Stripe (test mode for development)
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_CONNECT_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# PayPal (post-MVP, optional)
# ---------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Cron jobs
# ---------------------------------------------------------------------
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-random-32-byte-hex

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UUID of the system user used as opener for auto-opened auctions
# (created via service_role after first sign-up; placeholder for now).
SYSTEM_USER_ID=
